#include <math.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define W 800
#define H 800
#define MAXC 255

struct pt { double x, y; };
struct clr { double r, g, b; };
struct crv { struct pt *cp; int n; float ts, te; struct clr c; float th; };
struct img { int w, h, cd, mcv; char fmt[4]; int hs, ds; unsigned char *pd; };

struct pt bezier(float t, const struct crv *c) {
    struct pt r = {0,0};
    int n = c->n - 1;
    for (int i = 0; i <= n; i++) {
        double coef = 1;
        for (int j = 1; j <= i; j++) coef = coef * (n - j + 1) / j;
        double b = coef * pow(t, i) * pow(1 - t, n - i);
        r.x += b * c->cp[i].x;
        r.y += b * c->cp[i].y;
    }
    return r;
}

double dist(const struct pt *a, const struct pt *b) {
    double dx = a->x - b->x, dy = a->y - b->y;
    return sqrt(dx*dx + dy*dy);
}

struct clr getclr(const struct pt *p, const struct pt *pts, int n, const struct clr *cc, double th) {
    double md = 1;
    for (int i = 0; i < n; i++) { double d = dist(p, &pts[i]); if (d < md) md = d; }
    struct clr bg = {0.05, 0.05, 0.10};
    double sg = th * 0.3;
    double w = exp(-(md*md)/(2*sg*sg));
    return (struct clr){bg.r*(1-w)+cc->r*w, bg.g*(1-w)+cc->g*w, bg.b*(1-w)+cc->b*w};
}

void save(const struct img *im, const char *fn) {
    FILE *f = fopen(fn, "w");
    if (!f) { fprintf(stderr, "Error\n"); return; }
    fprintf(f, "P3\n%d %d\n%d\n", im->w, im->h, im->mcv);
    for (int j = 0; j < im->h; j++)
        for (int i = 0; i < im->w; i++) {
            int idx = (j*im->w + i)*3;
            fprintf(f, "%d %d %d\n", im->pd[idx], im->pd[idx+1], im->pd[idx+2]);
        }
    fclose(f);
}

int main() {
    struct pt ctrl[4] = {{0.10,0.85},{0.25,0.30},{0.70,0.35},{0.90,0.70}};
    struct crv c = {ctrl, 4, 0.0f, 1.0f, {0.4,0.8,0.2}, 0.025f};
    int seg = 200;
    struct pt *pts = malloc(seg * sizeof(struct pt));
    if (!pts) return 1;
    for (int i = 0; i < seg; i++) pts[i] = bezier((float)i/(seg-1), &c);
    struct img im = {W, H, 24, 255, "PPM", 0, W*H*3, malloc(W*H*3)};
    if (!im.pd) { free(pts); return 1; }
    for (int j = 0; j < H; j++)
        for (int i = 0; i < W; i++) {
            struct pt p = {(double)i/W, (double)j/H};
            struct clr pc = getclr(&p, pts, seg, &c.c, c.th);
            int idx = (j*W + i)*3;
            im.pd[idx] = pc.r*255.999;
            im.pd[idx+1] = pc.g*255.999;
            im.pd[idx+2] = pc.b*255.999;
        }
    save(&im, "out.ppm");
    free(pts); free(im.pd);
    return 0;
}
